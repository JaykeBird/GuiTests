<flat:ThemedWindow x:Class="DropTestWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DropTestWPF"
        xmlns:flat="clr-namespace:SolidShineUi;assembly=SolidShineUi"
        mc:Ignorable="d"
        Title="DataObject Inspector" Height="450" Width="400">
    <Grid>
        <flat:SelectPanel AllowDrop="True" x:Name="selPanel" DragEnter="selPanel_DragEnter" DragOver="selPanel_DragOver"
                          DragLeave="selPanel_DragLeave" Drop="selPanel_Drop" />
        <TextBlock x:Name="txtExplain" Text="Drag something in here or press Ctrl+V to paste something" 
                   IsHitTestVisible="False" VerticalAlignment="Center" HorizontalAlignment="Center" />
    </Grid>
</flat:ThemedWindow>
